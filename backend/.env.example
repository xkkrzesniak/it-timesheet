DATABASE_URL="postgresql://timesheet:password@localhost:5432/timesheet_db"
PORT=3001
HOST=0.0.0.0

# Microsoft Entra ID — tylko Tenant ID i Client ID, secret NIE jest wymagany
# Backend weryfikuje tokeny przez klucze publiczne JWKS, nie przez client secret
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# JWT (do podpisywania sesji)
JWT_SECRET=change-this-to-a-very-long-random-secret-min-32-chars

FRONTEND_URL=http://localhost:5173
NODE_ENV=development
