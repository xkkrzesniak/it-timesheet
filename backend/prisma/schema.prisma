generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  role       Role     @default(USER)
  hourlyRate Decimal  @default(0) @db.Decimal(10, 2)
  azureOid   String?  @unique
  isActive   Boolean  @default(true)
  weeklyGoalHours  Int?
  monthlyGoalHours Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  timeEntries   TimeEntry[]
  projectRates  UserProjectRate[]
  projectNotes  ProjectNote[]

  @@map("users")
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id       String  @id @default(cuid())
  name     String
  // Stawka sprzedażowa — WYŁĄCZNIE widoczna dla ADMINA
  // Backend nigdy nie zwraca tego pola do roli USER
  hourlyRate Decimal  @default(0) @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projects Project[]

  @@map("clients")
}

enum BillingType {
  HOURLY // praca na godzinę
  FIXED  // ryczałt / projekt opłacony z góry
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  clientId    String
  billingType  BillingType @default(HOURLY)
  hoursBudget  Int?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  client       Client           @relation(fields: [clientId], references: [id])
  timeEntries  TimeEntry[]
  userRates    UserProjectRate[]
  notes        ProjectNote[]

  @@map("projects")
}

// ─── Time Entries ─────────────────────────────────────────────────────────────

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  description String?
  date        DateTime @db.Date

  // Czas — timer lub ręczny wpis
  startTime DateTime?
  endTime   DateTime?
  // Zawsze zapisywane (obliczane z start/end lub podane ręcznie)
  minutes   Int

  tagId       String?
  tag         Tag?     @relation(fields: [tagId], references: [id])

  // SNAPSHOT STAWEK W MOMENCIE ZAPISU — krytyczna funkcja
  // Dzięki temu zmiany stawek nie modyfikują historycznych danych finansowych
  snapshotUserRate   Decimal @db.Decimal(10, 2)
  snapshotClientRate Decimal @db.Decimal(10, 2)

  // Pola obliczeniowe — przechowywane dla wydajności raportów
  costValue    Decimal @db.Decimal(10, 2) // minutes/60 × snapshotUserRate
  revenueValue Decimal @db.Decimal(10, 2) // minutes/60 × snapshotClientRate

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([userId, date])
  @@index([projectId, date])
  @@index([date])
  @@map("time_entries")
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id          String      @id @default(cuid())
  name        String      @unique
  color       String      @default('#6B7280')
  createdAt   DateTime    @default(now())
  timeEntries TimeEntry[]

  @@map("tags")
}

// ─── User-Project Rates ────────────────────────────────────────────────────────

model UserProjectRate {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  hourlyRate Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_rates")
}

// ─── Project Notes ────────────────────────────────────────────────────────────

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("project_notes")
}
