{
  "name": "it-timesheet-backend",
  "version": "1.0.0",
  "description": "IT Timesheet backend – Fastify + Prisma + PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "pdfkit": "^0.15.0",
    "csv-stringify": "^6.5.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "fastify-plugin": "^4.5.1",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/pdfkit": "^0.13.6",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
